local function LoadConfig()
    if not canSave() then
        warn("[NovaX Hub] No file functions. Save Config won't persist.")
        return
    end
    if not isfile(CONST.CONFIG_FILE) then return end
    local ok, decoded = pcall(function()
        return C.HttpService:JSONDecode(readfile(CONST.CONFIG_FILE))
    end)
    if ok and type(decoded) == "table" then
        for k, v in pairs(decoded) do
            Config[k] = v
        end
        if type(Config.Keybinds) ~= "table" then
            Config.Keybinds = {
                SpeedBoost = "Z",
                SpinBot = "X",
                GravityControl = "G",
                StepSpeed = "V",
                Unwalk = "B",
                Optimizer = "N",
                Protect = "P",
                AutoGrab = "T",
                InfiniteJump = "I",
            }
        end
        if type(Config.HopPower) ~= "number" then
            Config.HopPower = CONST.DEFAULT_JUMPPOWER
        end
        if type(Config.AutoGrab) ~= "boolean" then
            Config.AutoGrab = false
        end
        if type(Config.InfiniteJump) ~= "boolean" then
            Config.InfiniteJump = false
        end
        warn("[NovaX Hub] Config loaded.")
    end
end

local function SaveConfig()
    if not canSave() then
        warn("[NovaX Hub] Executor doesn't support writefile/readfile.")
        return
    end
    local ok, encoded = pcall(function()
        return C.HttpService:JSONEncode(Config)
    end)
    if ok then
        writefile(CONST.CONFIG_FILE, encoded)
        warn("[NovaX Hub] Config saved.")
    end
end

